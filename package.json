{
  "name": "did-vc-project",
  "version": "1.0.0",
  "description": "A comprehensive DID Verifiable Credentials project with Issuer, Holder, and Verifier modules",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:frontend": "vite build",
    "start": "node dist/index.js",
    "start:server": "node dist/server/index.js",
    "dev": "ts-node --esm src/index.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:frontend": "vite",
    "test": "jest"
  },
  "keywords": [
    "did",
    "verifiable-credentials",
