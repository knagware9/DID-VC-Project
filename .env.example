# Server
BACKEND_PORT=3001
FRONTEND_PORT=3000

# Database
DATABASE_URL=postgresql://didvc_user:didvc_pass@localhost:5432/didvc

# ── Hyperledger Besu Blockchain ────────────────────────────────────────────────
#
# By default the server runs in DEMO MODE — no real blockchain, transactions are
# simulated in-memory and reset on restart. The sidebar shows "Demo Mode".
#
# To go live on a local Besu dev network:
#   1. Start Besu:  docker-compose up besu -d
#   2. Deploy:      npm run deploy:besu
#   3. Copy DID_REGISTRY_ADDRESS + VC_REGISTRY_ADDRESS from .env.blockchain
#   4. Set BESU_PRIVATE_KEY to the pre-funded dev account below
#   5. Restart the server — sidebar switches to "Live: dev" (green)
#
# Besu dev mode pre-funded account:
#   Address:     0xfe3b557e8fb62b89f4916b721be55ceb828dbd73
#   Private key: 0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63
#
# For a custom permissioned network, update BESU_RPC_URL and BESU_CHAIN_ID.
# Optional: set BESU_EXPLORER_URL to a Blockscout instance for tx links.
#
BESU_NETWORK=dev
BESU_RPC_URL=http://localhost:8545
BESU_CHAIN_ID=1337

# Leave empty to stay in demo mode
BESU_PRIVATE_KEY=

# Optional Blockscout explorer (e.g. http://localhost:4000)
BESU_EXPLORER_URL=

# Contract addresses (copy from .env.blockchain after deploying)
DID_REGISTRY_ADDRESS=
VC_REGISTRY_ADDRESS=
