    "@noble/ed25519": "^2.3.0",
    "@noble/secp256k1": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "did-jwt": "^7.4.0",
    "did-jwt-vc": "^3.1.0",
    "did-resolver": "^4.1.0",
    "docx": "^9.6.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "key-did-provider-ed25519": "^3.0.0",
    "key-did-resolver": "^3.0.0",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zod": "^3.22.4"
