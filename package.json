{
  "name": "did-vc-project",
  "version": "1.0.0",
  "description": "A comprehensive DID Verifiable Credentials project with Issuer, Holder, and Verifier modules",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:frontend": "vite build",
    "start": "node dist/index.js",
    "start:server": "node dist/server/index.js",
    "dev": "ts-node --esm src/index.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:frontend": "vite",
    "test": "jest",
    "compile:contracts": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat compile",
    "deploy:besu": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/deploy-besu.cts --network besu",
    "deploy:local": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/deploy-besu.cts --network hardhat"
  },
  "keywords": [
    "did",
    "verifiable-credentials",
    "vc",
    "issuer",
    "holder",
    "verifier",
    "decentralized-identity"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/secp256k1": "^2.0.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "did-jwt": "^7.4.0",
    "did-jwt-vc": "^3.1.0",
    "did-resolver": "^4.1.0",
    "docx": "^9.6.1",
    "dotenv": "^17.4.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "key-did-provider-ed25519": "^3.0.0",
    "key-did-resolver": "^3.0.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^4.3.20",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "chai": "^4.5.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "jest": "^29.7.0",
    "solidity-coverage": "^0.8.17",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
